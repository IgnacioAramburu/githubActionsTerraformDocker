{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Service Health (UP)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds_aws" },
      "targets": [
        { "expr": "max(up{job=\"devops-app\"})", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": { "color": "red", "index": 1, "text": "DOWN" },
                "1": { "color": "green", "index": 0, "text": "UP" }
              },
              "type": "value"
            }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "textMode": "value" }
    },
    {
      "title": "Total Traffic (Last 24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds_aws" },
      "targets": [
        { "expr": "sum(increase(http_requests_total[24h]))", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "req" }
      },
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "center", "textMode": "value" }
    },
    {
      "title": "P95 Latency",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds_aws" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_ms_bucket[5m])) by (le))", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 150 },
              { "color": "red", "value": 400 }
            ]
          }
        }
      }
    },
    {
      "title": "Error Rate (%)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds_aws" },
      "targets": [
        { "expr": "sum(rate(http_requests_total{status_code=~\"4..|5..\"}[5m])) / sum(rate(http_requests_total[5m])) * 100", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "textMode": "value" }
    },
    {
      "title": "Requests per Second (RPS) by Route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds_aws" },
      "targets": [
        { "expr": "sum by (route, method) (rate(http_requests_total[5m]))", "legendFormat": "{{method}} {{route}}", "refId": "A" }
      ],
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "title": "Response Status Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus_ds_aws" },
      "targets": [
        { "expr": "sum by (status_code) (http_requests_total)", "legendFormat": "Status {{status_code}}", "refId": "A" }
      ],
      "options": { "legend": { "displayMode": "list", "placement": "right" } }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["aws", "telemetry", "fastapi"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Global Application Telemetry",
  "uid": "app_telemetry_dashboard",
  "version": 1
}